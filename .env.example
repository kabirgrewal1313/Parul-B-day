# ---------------------------------------------------------------------------
# Frontend (Next.js) — copy to .env.local
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_BASE=/api

# Optional: only needed if you call Supabase directly from the browser later
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------------------------
# Backend (FastAPI) — used when running uvicorn
# ---------------------------------------------------------------------------

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=memory-images

# Optional production frontend URL for CORS
FRONTEND_URL=
